{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "jsx-a11y"],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/dist-ssr/**",
    "**/coverage/**",
    "**/playwright-report/**",
    "**/test-results/**",
    "client/tests/visual/**/*.png"
  ],
  "settings": {
    "react": {
      "version": "19.1.0"
    }
  }
}
